# ══════════════════════════════════════════════════════════
# LinkedIn Scraper — Docker Environment Variables
# Copy this to .env.docker and fill in your values
# ══════════════════════════════════════════════════════════

# ── Required: AI APIs ──
GROQ_API_KEY=your_groq_api_key_here
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ── Required: LinkedIn Session Cookie ──
# Get from browser: DevTools → Application → Cookies → linkedin.com → li_at
# Multiple cookies (comma-separated) for rotation: cookie1,cookie2
LI_AT=your_li_at_cookie_here

# ── Required: Google Search (for lead discovery) ──
SERPER_API_KEY=your_serper_api_key_here

# ── Optional: Google Sheets ──
GOOGLE_SHEET_ID=
GOOGLE_SHEETS_CREDS=portfolio-1735565372509-7455fd6c2451.json

# ── Server ──
PORT=5000
